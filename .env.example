# Telegram bot token from @BotFather (required)
BOT_TOKEN=

# HTTP server port for one-time links
PORT=3000

# Public base URL used in generated links (no trailing slash).
# For real usage expose the server publicly (e.g. via a tunnel) and put that URL here.
BASE_URL=http://localhost:3000

# SQLite database file for saved secrets
DATABASE_PATH=secrets.sqlite

# One-time link lifetime in minutes
LINK_TTL_MINUTES=5
