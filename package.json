{
  "name": "secret-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --hot src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute secret-manager --remote --file schema.sql -y"
  },
  "dependencies": {
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0",
    "wrangler": "^4.100.0"
  }
}
